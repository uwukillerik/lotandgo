# PostgreSQL — локальная установка (без Docker)
# Windows: https://www.postgresql.org/download/windows/
# macOS: brew install postgresql@16 && brew services start postgresql@16
DATABASE_URL=postgresql://lotgo:lotgo@localhost:5432/lotgo

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Локальная разработка
# CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:19006

# Продакшен (Keenetic: снаружи 7080→80, 3454→443)
CORS_ORIGIN=http://lotgo.ru:7080,https://lotgo.ru:3454,http://www.lotgo.ru:7080,https://www.lotgo.ru:3454,http://77.50.193.34:7080,https://77.50.193.34:3454

UPLOAD_DIR=uploads
PORT=8081
HOST=127.0.0.1

# Оплата: local (тест, по умолчанию) | stripe | none
# ЮKassa подключим позже; Stripe не нужен для разработки
PAYMENT_PROVIDER=local

# Stripe — только если PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
